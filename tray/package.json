{
  "name": "mad-for-audio-tray",
  "version": "1.0.0",
  "description": "Mad for Audio — 시스템 트레이(Windows)·메뉴바(macOS) 라디오 플레이어",
  "main": "main.js",
  "private": true,
  "author": "ducklove",
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "check": "node --check main.js && node --check preload.js",
    "audit": "npm audit --audit-level=high"
  },
  "devDependencies": {
    "electron": "43.1.1",
    "electron-builder": "26.15.3"
  },
  "build": {
    "appId": "com.madforaudio.tray",
    "productName": "Mad for Audio",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "shell.html"
    ],
    "extraResources": [
      { "from": "../widget.html", "to": "web/widget.html" },
      { "from": "../stations.js", "to": "web/stations.js" },
      { "from": "../player-core.js", "to": "web/player-core.js" },
      { "from": "../icons", "to": "web/icons" }
    ],
    "win": {
      "target": ["portable"],
      "icon": "../icons/icon-512.png"
    },
    "mac": {
      "target": ["zip"],
      "icon": "../icons/icon-512.png",
      "category": "public.app-category.music",
      "extendInfo": {
        "LSUIElement": true
      }
    }
  }
}
